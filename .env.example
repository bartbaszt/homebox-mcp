# Required: one Homebox instance for this MCP server.
HOMEBOX_BASE_URL=https://homebox.example.com

# Remote MCP endpoint. Use 0.0.0.0 when exposing outside localhost.
HOMEBOX_MCP_HOST=0.0.0.0
HOMEBOX_MCP_PORT=3000
HOMEBOX_MCP_PATH=/mcp

# Required for exposed deployments. External agents send:
# Authorization: Bearer <HOMEBOX_MCP_API_TOKEN>
HOMEBOX_MCP_API_TOKEN=change-me

# Optional direct HTTPS. Prefer reverse proxy TLS in production.
# HOMEBOX_MCP_TLS_KEY=C:\\certs\\homebox-mcp.key
# HOMEBOX_MCP_TLS_CERT=C:\\certs\\homebox-mcp.crt

# Safety limits.
HOMEBOX_API_TIMEOUT_MS=30000
HOMEBOX_MCP_MAX_UPLOAD_BYTES=10485760
HOMEBOX_MCP_MAX_DOWNLOAD_BYTES=10485760

# Real E2E tests can read HomeboxAiHelper credentials without copying secrets.
HOMEBOX_TEST_ACCESS_FILE=C:\\__program\\HomeboxAiHelper\\.test-access
