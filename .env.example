# Required: one Homebox instance for this MCP server.
HOMEBOX_BASE_URL=https://homebox.example.com

# Remote MCP endpoint. Use 0.0.0.0 when exposing outside localhost.
HOMEBOX_MCP_HOST=0.0.0.0
HOMEBOX_MCP_PORT=3000
HOMEBOX_MCP_PATH=/mcp

# Docker Compose host port. App ignores this; compose uses it for port publishing.
HOMEBOX_MCP_PUBLISH_PORT=3000

# Static MCP auth option. Required when listening on non-local hosts unless OAuth is enabled.
# External agents send:
# Authorization: Bearer <HOMEBOX_MCP_API_TOKEN>
# HOMEBOX_MCP_API_TOKEN=replace-with-a-long-random-token

# OAuth MCP auth option for ChatGPT Apps/Connectors.
# Set the public HTTPS /mcp URL when behind a reverse proxy/tunnel.
# ChatGPT stores the OAuth access/refresh token in the connector configuration.
# HOMEBOX_MCP_OAUTH_ENABLED=true
# HOMEBOX_MCP_PUBLIC_URL=https://mcp.example.com/mcp
# HOMEBOX_MCP_OAUTH_ISSUER=https://mcp.example.com
# Exact reverse-proxy addresses/CIDRs, comma-separated. "true" trusts loopback only.
# HOMEBOX_MCP_TRUST_PROXY=127.0.0.1,::1
# HOMEBOX_MCP_OAUTH_ACCESS_TOKEN_TTL_SECONDS=3600
# HOMEBOX_MCP_OAUTH_REFRESH_TOKEN_TTL_SECONDS=2592000
# HOMEBOX_MCP_OAUTH_AUTH_CODE_TTL_SECONDS=300
# HOMEBOX_MCP_OAUTH_ALLOW_INSECURE_HTTP=false

# Persist OAuth client registrations and tokens so ChatGPT connectors survive restarts.
# This file contains Homebox tokens; keep the mounted directory private.
HOMEBOX_MCP_DATA_DIR=/data

# Optional server-local photo directory. filePath tools stay disabled unless set.
# Mount a dedicated read-only directory; never use HOMEBOX_MCP_DATA_DIR or a secrets directory.
# HOMEBOX_MCP_LOCAL_FILE_ROOT=/photos

# Optional direct HTTPS. Prefer reverse proxy TLS in production.
# HOMEBOX_MCP_TLS_KEY=C:\\certs\\homebox-mcp.key
# HOMEBOX_MCP_TLS_CERT=C:\\certs\\homebox-mcp.crt

# Safety limits.
HOMEBOX_API_TIMEOUT_MS=30000
HOMEBOX_MCP_MAX_UPLOAD_BYTES=10485760
HOMEBOX_MCP_MAX_DOWNLOAD_BYTES=10485760

# Real E2E tests can read HomeboxAiHelper credentials without copying secrets.
HOMEBOX_TEST_ACCESS_FILE=C:\\__program\\HomeboxAiHelper\\.test-access
