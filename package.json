{
  "name": "homebox-mcp",
  "version": "0.1.0",
  "description": "Remote HTTP/HTTPS MCP server for one Homebox instance, many collections and users.",
  "type": "module",
  "license": "AGPL-3.0-or-later",
  "private": true,
  "bin": {
    "homebox-mcp": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "check": "npm run build && npm run test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "tsx": "^4.22.4",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
